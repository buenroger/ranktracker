# =============================================================================
# Rank Tracker — variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# =============================================================================

# --- Base de datos MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ranktracker
DB_USER=ranktracker
DB_PASSWORD=cambia_esto

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Google Search Console ---
# Ruta al fichero de credenciales OAuth2 descargado desde Google Cloud Console
GSC_CREDENTIALS_FILE=gsc_credentials.json
# Ruta donde se guardará el token tras el primer login interactivo
GSC_TOKEN_FILE=gsc_token.json
# Días atrás a pedir en cada ingesta (GSC tiene ~3 días de retraso)
GSC_LOOKBACK_DAYS=3

# --- DataForSEO ---
DATAFORSEO_LOGIN=tu_email@ejemplo.com
DATAFORSEO_PASSWORD=tu_password_dataforseo

# --- Alertas por email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASSWORD=tu_app_password_gmail
ALERT_FROM_EMAIL=ranktracker@tudominio.com

# --- General ---
DEBUG=false
APP_ENV=production
